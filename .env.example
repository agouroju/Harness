# --- ClickHouse Cloud (console.clickhouse.cloud) ---
CLICKHOUSE_HOST=xxxxx.us-east-1.aws.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=radar

# --- Senso (docs.senso.ai -> API key) ---
SENSO_API_KEY=tgr_...
# Optional: pin a specific geo question/prompt id if your org requires it for drafts
SENSO_QUESTION_ID=

# --- LLM (any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # optional: OpenRouter/gateway
LLM_MODEL=gpt-4o-mini

# --- Langfuse (cloud.langfuse.com) optional, enables tracing ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- GitHub (optional, raises rate limit for direct ingest) ---
GITHUB_TOKEN=

# --- Radar behavior ---
INGEST_MODE=direct        # direct | airbyte (airbyte = skip built-in pull, data arrives via Airbyte)
RADAR_INTERVAL_MIN=60
RADAR_LOOKBACK_HOURS=24
