# --- ClickHouse Cloud (console.clickhouse.cloud) ---
CLICKHOUSE_HOST=xxxxx.us-east-1.aws.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=radar

# --- Senso (docs.senso.ai -> API key) ---
SENSO_API_KEY=tgr_...
# Optional: pin a specific geo question/prompt id if your org requires it for drafts
SENSO_QUESTION_ID=

# --- LLM (any OpenAI-compatible endpoint) ---
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1   # optional: OpenRouter/gateway
LLM_MODEL=gpt-4o-mini

# --- Langfuse (cloud.langfuse.com) optional, enables tracing ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Airbyte Cloud API (for web-managed syncs) ---
AIRBYTE_API_URL=https://api.airbyte.com/v1
AIRBYTE_API_TOKEN=
AIRBYTE_SYNC_WAIT_SECONDS=120

# --- GitHub (optional, raises rate limit for direct ingest) ---
GITHUB_TOKEN=

# --- Radar behavior ---
INGEST_MODE=airbyte       # direct is legacy-only; web/scheduled runs use Airbyte-managed data
RADAR_INTERVAL_MIN=60
RADAR_LOOKBACK_HOURS=24
TRACKED_REPOS_FILE=tracked_repos.txt
# TRACKED_REPOS=owner/repo,another-owner/another-repo  # optional additions
HN_COMMENT_STORY_LIMIT=8
HN_COMMENT_LIMIT=30
HN_PAGE_STORY_LIMIT=8
HN_PAGE_TEXT_LIMIT=5000

# --- Web app / scheduler ---
WEB_RUN_INTERVAL_HOURS=6
WEB_SCHEDULER_ENABLED=true
WEB_USERNAME=admin
WEB_PASSWORD=
